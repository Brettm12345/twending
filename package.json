{
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^22.13.11",
    "husky": "^9.1.7",
    "turbo": "^2.5.4",
    "ultracite": "7.6.0"
  },
  "name": "twending",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F @twending/web dev",
    "serve:web": "turbo -F @twending/web serve",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "packageManager": "pnpm@10.20.0"
}
